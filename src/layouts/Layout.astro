---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import Identity from '../components/Identity.astro';
import Footer from '../components/Footer.astro';
import SkipLink from '../components/SkipLink.astro';
import ThemeDrawer from '../components/ThemeDrawer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Dave Musson — Design Systems and Accessibility specialist',
  ogImage = '/og/og-default.png',
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://mussond.com');
const isHomepage = Astro.url.pathname === '/';
const shortcutTarget = isHomepage ? 'panel' : 'drawer';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script>
      (function() {
        var t = localStorage.getItem('theme');
        var c = localStorage.getItem('contrast');
        var systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var systemHigh = window.matchMedia('(prefers-contrast: more)').matches;
        var theme = (t === 'light' || t === 'dark') ? t : (systemDark ? 'dark' : 'light');
        var contrast = (c === 'low' || c === 'high' || c === 'decorative') ? c : (systemHigh ? 'high' : 'low');
        document.documentElement.className = theme;
        document.documentElement.setAttribute('data-contrast', contrast);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, canonicalUrl).toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, canonicalUrl).toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/favicon@2x.png" />
    <link rel="preload" href="/fonts/geist-sans/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/instrument-serif/InstrumentSerif-Italic.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
  </head>
  <body data-shortcut-target={shortcutTarget}>
    <SkipLink />
    <Sidebar />
    <header class="site-header">
      {isHomepage && (
        <p class="site-header__role text-eyebrow">
          Principal designer &middot; a11y &amp; design systems
        </p>
      )}
      <Identity variant="mobile" />
    </header>
    <slot />
    <Footer />
    <ThemeDrawer />
  </body>
</html>

<script>
  import '../scripts/display-controls';
</script>