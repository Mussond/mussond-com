---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import SkipLink from '../components/SkipLink.astro';
import ThemeDrawer from '../components/ThemeDrawer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Dave Musson — Design Systems and Accessibility specialist' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script>
      (function() {
        var t = localStorage.getItem('theme');
        var c = localStorage.getItem('contrast');
        var systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var systemHigh = window.matchMedia('(prefers-contrast: more)').matches;
        var theme = (t === 'light' || t === 'dark') ? t : (systemDark ? 'dark' : 'light');
        var contrast = (c === 'low' || c === 'high' || c === 'decorative') ? c : (systemHigh ? 'high' : 'low');
        document.documentElement.className = theme;
        document.documentElement.setAttribute('data-contrast', contrast);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/favicon@2x.png" />
    <link rel="preload" href="/fonts/geist-sans/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/instrument-serif/InstrumentSerif-Italic.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
  </head>
  <body>
    <SkipLink />
    <Sidebar />
    <slot />
    <Footer />
    <ThemeDrawer />
  </body>
</html>