---
const footerLinks = [
  { label: 'About me', href: '/about' },
  { label: 'About this site', href: '/about-this-site' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/davemusson/', external: true },
  { label: 'GitHub', href: 'https://github.com/Mussond', external: true },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer">
    <nav class="footer__nav" aria-label="Secondary">
      <ul class="footer__list" role="list">
        {footerLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="footer__link"
              {...link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
            >
              {link.label}{link.external && <span class="visually-hidden"> (opens in new tab)</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <p class="footer__copyright">© {currentYear} Dave Musson</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    border-top: 2px solid var(--color-border-default);
    padding-block: 2.5rem;
  }

  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__link {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: underline 0.15em;
    text-underline-offset: 0;
    text-decoration-color: transparent;
    padding: 0.4rem 0.75rem;
    border-radius: 4px;
    transition: text-underline-offset 600ms, text-decoration-color 400ms;
  }

  .footer__link:hover,
  .footer__link:focus-visible {
    text-decoration-color: var(--color-text-primary);
    text-underline-offset: 0.4em;
    outline: none;
  }

  .footer__copyright {
    font-size: 0.875rem;
    color: var(--color-text-primary);
    opacity: 0.6;
    max-width: unset;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 800px) {
    .footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }
</style>
