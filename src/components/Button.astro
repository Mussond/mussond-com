---
interface Props {
  variant?: 'primary' | 'secondary';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  class: className,
} = Astro.props;

const classes = ['btn', `btn--${variant}`, className].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes}>
    <span class="btn__label"><slot /></span>
  </a>
) : (
  <button type={type} class={classes}>
    <span class="btn__label"><slot /></span>
  </button>
)}
