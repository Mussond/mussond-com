---
interface Props {
  variant?: 'primary' | 'secondary' | 'utility';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  id?: string;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  class: className,
  id,
} = Astro.props;

const hasIcon = Astro.slots.has('icon');
const classes = ['btn', `btn--${variant}`, hasIcon ? 'btn--has-icon' : '', className].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} id={id}>
    <span class="btn__label"><slot /></span>
    {hasIcon && <span class="btn__icon" aria-hidden="true"><slot name="icon" /></span>}
  </a>
) : (
  <button type={type} class={classes} id={id}>
    <span class="btn__label"><slot /></span>
    {hasIcon && <span class="btn__icon" aria-hidden="true"><slot name="icon" /></span>}
  </button>
)}