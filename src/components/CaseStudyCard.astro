---
import TagList from './TagList.astro';

interface Stat {
  label: string;
  value: string;
}

interface Cover {
  slug: string;
  brand?: string;
  tag?: string;
  label: string;
  meta: string;
}

interface Props {
  variant: 'featured' | 'secondary' | 'row';
  href: string;
  title: string;
  description?: string;
  tags?: string[];
  year?: string | number;
  stats?: Stat[];
  cover?: Cover;
  image?: string;
  imageAlt?: string;
  headingLevel?: 2 | 3;
}

const {
  variant,
  href,
  title,
  description,
  tags = [],
  year,
  stats,
  cover,
  image,
  imageAlt = '',
  headingLevel = 3,
} = Astro.props;

const Heading = `h${headingLevel}` as 'h2' | 'h3';
const hasCover = Boolean(cover);
const slug = cover?.slug ?? '';
const isFeatured = variant === 'featured';
const isRow = variant === 'row';
const rowTitle = isRow && cover?.brand ? `${cover.brand} — ${title}` : title;
const showStats = isFeatured && stats !== undefined && stats.length > 0;
// Featured shows year in the plate; secondary prepends year to its tag list
const metaTags = !isFeatured && !isRow && year !== undefined ? [String(year), ...tags] : tags;
const coverStyle = hasCover ? `--card-bg: var(--cover-${slug}-bg); --card-fg: var(--cover-${slug}-fg)` : undefined;
---

{isRow ? (
  <a href={href} class="cs-card cs-card--row" style={coverStyle}>
    <span class="cs-card__row-tile" aria-hidden="true">{cover?.tag ?? cover?.brand?.slice(0, 3).toUpperCase()}</span>
    <span class="cs-card__row-body">
      <Heading class="cs-card__row-title">{rowTitle}</Heading>
      {tags.length > 0 && <span class="cs-card__row-meta">{tags.join(' · ')}</span>}
    </span>
    {year && <span class="cs-card__row-year">{year} →</span>}
  </a>
) : (
  <a
    href={href}
    class={`cs-card cs-card--${variant}${hasCover ? ' cs-card--cover' : ''}`}
    style={coverStyle}
  >
    {hasCover ? (
      <div class="cs-card__block">
        {cover!.brand && (
          <span class="cs-card__brand" aria-hidden="true">{cover!.brand}</span>
        )}
        {year && (
          <span class="cs-card__year" aria-hidden="true">{year}</span>
        )}
      </div>
    ) : image ? (
      <img
        src={image}
        alt={imageAlt}
        class="cs-card__image"
        loading="lazy"
        decoding="async"
      />
    ) : null}

    <div class="cs-card__content">
      <Heading class="cs-card__title">{title}</Heading>
      {description && <p class="cs-card__description">{description}</p>}
      {showStats && (
        <dl class="cs-card__stats">
          {stats!.map((stat) => (
            <div class="cs-card__stat">
              <dt class="cs-card__stat-label">{stat.label}</dt>
              <dd class="cs-card__stat-value">{stat.value}</dd>
            </div>
          ))}
        </dl>
      )}
      <TagList tags={metaTags} size="xs" />
    </div>
  </a>
)}