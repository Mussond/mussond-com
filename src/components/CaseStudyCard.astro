---
import TagList from './TagList.astro';

interface Cover {
  slug: string;
  brand?: string;
  label: string;
  meta: string;
}

interface Props {
  variant: 'featured' | 'secondary';
  href: string;
  title: string;
  description?: string;
  tags?: string[];
  year?: string | number;
  cover?: Cover;
  image?: string;
  imageAlt?: string;
  headingLevel?: 2 | 3;
}

const {
  variant,
  href,
  title,
  description,
  tags = [],
  year,
  cover,
  image,
  imageAlt = '',
  headingLevel = 3,
} = Astro.props;

const metaTags = year ? [String(year), ...tags] : tags;

const Heading = `h${headingLevel}` as 'h2' | 'h3';
const hasCover = Boolean(cover);
const slug = cover?.slug ?? '';
---

<a
  href={href}
  class={`cs-card cs-card--${variant}${hasCover ? ' cs-card--cover' : ''}`}
  style={hasCover ? `--card-bg: var(--cover-${slug}-bg); --card-fg: var(--cover-${slug}-fg)` : undefined}
>
  {hasCover ? (
    <div class="cs-card__block">
      {cover!.brand && (
        <span class="cs-card__brand" aria-hidden="true">{cover!.brand}</span>
      )}
      <span class="cs-card__label" aria-hidden="true">{cover!.label}</span>
    </div>
  ) : image ? (
    <img
      src={image}
      alt={imageAlt}
      class="cs-card__image"
      loading="lazy"
      decoding="async"
    />
  ) : null}

  <div class="cs-card__content">
    <Heading class="cs-card__title">{title}</Heading>
    {description && <p class="cs-card__description">{description}</p>}
    <TagList tags={metaTags} size="xs" />
  </div>
</a>
