---
// Hero — homepage opener. Board 4a: eyebrow (amber tick) → 54px
// stance H1 (weight 650, amber-text emphasis on the closing phrase —
// decision 5, not the board's inset highlighter) → 22px lead →
// primary/secondary CTAs. Per the 4a/5a boards, the
// eyebrow lives here (below SiteHeader), not in the header itself —
// the header only ever carries the logo + wordmark + nav. The stance
// line is the page's h1 (boards mark it up as <h1>; SiteHeader's
// wordmark is plain text, not a heading, per decision #4 — "Dave
// Musson" H1 is retired). Stats live in HeroStats.astro, directly
// after this section, continuing the same visual block.
import Button from './Button.astro';
---

<section class="hero container" aria-label="Introduction">
  <div class="hero__eyebrow-row">
    <p class="hero__role">
      Principal designer · a11y &amp; design systems
    </p>
    <p class="hero__shortcut-hint text-eyebrow">
      Press <kbd class="hero__kbd" data-kbd-glyph>⌥ + T</kbd> to jump to display settings
    </p>
  </div>

  <h1 class="hero__stance">
    Accessibility isn't a feature. It's a <span class="hero__emphasis">usability amplifier</span>.
  </h1>

  <p class="hero__lead">
    Design systems and accessibility specialist. Helping product teams build things that work
    regardless of how you access them.
  </p>

  <div class="hero__ctas">
    <Button href="/case-studies" variant="primary">Selected work →</Button>
    <Button href="/about" variant="secondary">About me</Button>
  </div>

<script is:inline>
  (function () {
    var isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform);
    if (!isMac) {
      document.querySelectorAll('[data-kbd-glyph]').forEach(function (g) {
        g.textContent = 'Alt + T';
      });
    }
  })();
</script>

<style>
  .hero {
    padding-block: 1.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero__eyebrow-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-p4);
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  /* Role eyebrow — amber tick + 14px sans uppercase, matches the
     section-header eyebrow treatment (board 4a/4b consistent pattern). */
  .hero__role {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    max-width: none;
  }

  .hero__role::before {
    content: '';
    width: 1.5rem;
    height: var(--stroke-2);
    background: var(--color-eyebrow-dash);
    flex-shrink: 0;
  }

  .hero__shortcut-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    color: var(--color-text-secondary);
    max-width: none;
  }

  .hero__kbd {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.5rem;
    border: var(--stroke-1) solid var(--color-border-base);
    border-radius: var(--radius-r1);
    background: var(--color-bg-card);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: none;
    color: var(--color-text-primary);
  }

  .hero__stance {
    font-family: var(--font-sans);
    font-weight: 650;
    font-size: var(--text-3xl);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 22ch;
    text-wrap: pretty;
  }

  /* Amber text is the only emphasis treatment, in every flourish state
     (phase 7B decision 5 — the board's inset-highlighter alternative
     was reviewed live 2026-07-22 and Dave chose to keep this instead). */
  .hero__emphasis {
    color: var(--amber-11);
  }

  html.dark .hero__emphasis {
    color: var(--amber-9);
  }

  .hero__lead {
    margin: 0;
    font-size: var(--text-md);
    line-height: 1.5;
    color: var(--color-text-secondary);
    max-width: 55ch;
  }

  .hero__ctas {
    display: flex;
    align-items: center;
    gap: var(--space-p4);
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  @media (max-width: 800px) {
    .hero__stance {
      font-size: 2.5rem;
    }

    .hero__shortcut-hint {
      display: none;
    }
  }
</style>
