---
// Hero — homepage opener. Eyebrow row pairs role with the keyboard
// shortcut hint (platform-detected glyph). Stance follows v2: italic
// serif, single line break, "usability amplifier" emphasised in amber.
// Stats live in HeroStats.astro — DisplaySettings sits between them.
---

<section class="hero container" aria-label="Introduction">
  <div class="hero__eyebrow-row">
    <p class="hero__role text-eyebrow">
      Principal designer · a11y &amp; design systems
    </p>
    <p class="hero__shortcut-hint text-eyebrow">
      Press <kbd class="hero__kbd" id="hero-kbd-glyph">⌘ + ⇧ + K</kbd> to toggle display settings
    </p>
  </div>

<p class="hero__stance">
    Accessibility isn't a feature. <br />
    It's a <em class="hero__emphasis">usability amplifier</em>.
  </p>

<script is:inline>
  (function () {
    var isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform);
    if (!isMac) {
      var glyph = document.getElementById('hero-kbd-glyph');
      if (glyph) glyph.textContent = 'Ctrl + Shift + K';
    }
  })();
</script>

<style>
  .hero {
    padding-block: 4rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .hero__eyebrow-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero__role {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    color: var(--color-text-primary);
    max-width: none;
  }

  .hero__shortcut-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    color: var(--color-text-secondary);
    max-width: none;
  }

  .hero__kbd {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.5rem;
    border: var(--stroke-1) solid var(--color-border-base);
    border-radius: var(--radius-r1);
    background: var(--color-bg-card);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: none;
    color: var(--color-text-primary);
  }

  .hero__stance {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: var(--text-3xl);
    line-height: 1.1;
    margin: 0;
    max-width: none;
  }

.hero__emphasis {
    font-style: italic;
    color: var(--amber-11);
  }

  html.dark .hero__emphasis {
    color: var(--amber-9);
  }

  @media (max-width: 800px) {
    .hero__stance {
      font-size: 2.5rem;
    }
  }
</style>