---
import Button from './Button.astro';
---

<section class="hero container" aria-label="Introduction">
  <p class="hero__stance">
    Accessibility isn't a feature. <br> It's a usability amplifier.
  </p>
  <p class="text-leading hero__intro">
    16 years helping product
    teams build things that work regardless of how you access them.
  </p>
</section>

<style>
  .hero {
    padding-block: 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero__intro { max-width: 78ch; }

  .hero__stance {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: var(--text-2xl);
    line-height: 1.1;
    margin-top: 0.5rem;
  }

  @media (max-width: 800px) {
    .hero__stance { font-size: 2.5rem; }
  }

</style>
