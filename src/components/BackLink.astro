---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<a href={href} class="back-link">← {label}</a>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    font-weight: 600;
    text-decoration: underline 0.15em;
    text-underline-position: under;
  }
</style>
