---
interface Props {
  href: string;
  title: string;
  description?: string;
  year?: number;
  headingLevel?: 2 | 3;
  external?: boolean;
}

const { href, title, description, year, headingLevel = 3, external = false } = Astro.props;
const Heading = `h${headingLevel}` as 'h2' | 'h3';
---

<a
  href={href}
  class="log-card"
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  <div class="log-card__body">
    <Heading class="log-card__title">
      {title}
      {external && (
        <span class="log-card__external-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h6v6M10 14 21 3M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
          </svg>
        </span>
        <span class="visually-hidden"> (opens in new tab)</span>
      )}
    </Heading>
    {description && <p class="log-card__description">{description}</p>}
  </div>
  {year && <span class="log-card__meta">{year}</span>}
</a>
