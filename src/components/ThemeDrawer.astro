---
// ThemeDrawer — display settings dialog opened from the sidebar
// theme-toggle icon button on every page, and from Cmd/Ctrl+Shift+K
// on non-homepage routes. Renders DisplayControls in stacked-drawer
// variant. Wiring lives in src/scripts/display-controls.ts (loaded
// once from Layout.astro).
import DisplayControls from './DisplayControls.astro';
---

<dialog id="theme-drawer" class="theme-drawer" aria-labelledby="theme-drawer-title">
  <header class="theme-drawer__header">
    <h2 id="theme-drawer-title" class="theme-drawer__title">Display settings</h2>
    <button
      type="button"
      class="theme-drawer__close"
      data-theme-drawer-close
      aria-label="Close settings"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </header>

  <p class="theme-drawer__forced-colors-note">
    System high-contrast is active. These settings will have no visual effect.
  </p>

  <DisplayControls variant="drawer" idPrefix="drawer" />

  <p class="theme-drawer__explainer">
    Decorative is a lower-contrast mode for visual enjoyment. Some text and UI may not meet WCAG AA. Choose Low or High if readability matters to you.
  </p>
</dialog>