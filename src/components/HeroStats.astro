---
// HeroStats — board 4a: a bordered-top row directly under the hero's
// CTAs, not a separate section. Two numeric columns (years, systems)
// then a wide orgs column last, so the long org list wraps without
// squeezing the numbers. Rendered as <dl> for description-list
// semantics.
---

<section class="hero-stats container" aria-label="Profile stats">
  <dl class="hero-stats__list">
    <div class="hero-stats__item">
      <dt class="hero-stats__label">Years practising</dt>
      <dd class="hero-stats__value hero-stats__value--numeric">16</dd>
    </div>
    <div class="hero-stats__item">
      <dt class="hero-stats__label">Design systems shipped</dt>
      <dd class="hero-stats__value hero-stats__value--numeric">7</dd>
    </div>
    <div class="hero-stats__item hero-stats__item--wide">
      <dt class="hero-stats__label">Orgs worked with</dt>
      <dd class="hero-stats__value">Dojo, ustwo, LSEG, Checkout.com, Coursera, Aviva, LBG</dd>
    </div>
  </dl>
</section>

<style>
  .hero-stats {
    padding-block: 2rem 0;
  }

  .hero-stats__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-p14);
    margin: 0;
    padding-top: var(--space-p8);
    border-top: var(--stroke-1) solid var(--color-border-base);
  }

  .hero-stats__item {
    display: flex;
    flex-direction: column;
    margin: 0;
  }

  .hero-stats__item--wide {
    min-width: 0;
    flex: 1 1 auto;
  }

  .hero-stats__label {
    order: 2;
    margin: 0.25rem 0 0;
    /* dt precedes dd in the DOM for correct dl semantics;
       order flips the visual stack so the value reads on top,
       matching board 4a. */
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    max-width: none;
  }

  .hero-stats__value {
    order: 1;
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-md);
    line-height: 1.4;
    color: var(--color-text-primary);
    max-width: none;
  }

  .hero-stats__value--numeric {
    font-weight: 650;
    font-size: var(--text-xl);
    line-height: 1.1;
  }

  @media (max-width: 800px) {
    .hero-stats__list {
      flex-direction: column;
      gap: var(--space-p6);
    }

    .hero-stats__value--numeric {
      font-size: var(--text-xl);
    }
  }
</style>