---
import { ArrowRight } from 'lucide-astro';
import Button from './Button.astro';

interface Props {
  eyebrow: string;
  heading: string;
  headingId: string;
  viewAllHref?: string;
  viewAllLabel?: string;
}

const { eyebrow, heading, headingId, viewAllHref, viewAllLabel } = Astro.props;
---

<div class="section-header">
  <div class="section-header__left">
    <p class="section-header__eyebrow">{eyebrow}</p>
    <h2 id={headingId} class="section-header__heading">{heading}</h2>
  </div>
  {viewAllHref && (
    <Button href={viewAllHref} variant="secondary" class="section-header__cta">
      {viewAllLabel ?? 'View all'}<span class="visually-hidden"> {eyebrow.toLowerCase()}</span>
      <ArrowRight slot="icon" aria-hidden="true" width="16" height="16" />
    </Button>
  )}
</div>
