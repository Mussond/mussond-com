---
import { Sun, Moon } from 'lucide-astro';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Case studies', href: '/case-studies' },
  { label: 'Guides', href: '/guides' },
  { label: 'Logs', href: '/logs' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <nav class="container nav" aria-label="Main">
    <a href="/" class="nav__logo" aria-label="Dave Musson — home">
      <span aria-hidden="true">DM</span>
    </a>
    <ul id="nav-list" class="nav__list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav__link"
            aria-current={currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'page' : undefined}
          >{link.label}</a>
        </li>
      ))}
    </ul>
    <button
      type="button"
      class="nav__theme-toggle"
      aria-label="Theme and contrast settings"
      aria-haspopup="dialog"
      aria-controls="theme-drawer"
      onclick="document.getElementById('theme-drawer').showModal()"
    >
      <Sun class="nav__theme-toggle-icon nav__theme-toggle-icon--sun" aria-hidden="true" width="20" height="20" />
      <Moon class="nav__theme-toggle-icon nav__theme-toggle-icon--moon" aria-hidden="true" width="20" height="20" />
    </button>
    <button class="nav__menu-toggle" aria-expanded="false" aria-controls="nav-list" aria-label="Open menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
    </button>
  </nav>
</header>

<script>
  const toggle = document.querySelector('.nav__menu-toggle') as HTMLButtonElement;
  const list = document.querySelector('.nav__list') as HTMLUListElement;

  function updateMenuLabel(isOpen: boolean) {
    toggle?.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = list.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    updateMenuLabel(isOpen);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    if (!list.classList.contains('is-open')) return;

    list.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    updateMenuLabel(false);
    toggle?.focus();
  });
</script>