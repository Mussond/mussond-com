---
// DisplayControls — segmented radio groups for theme, contrast, and
// flourish. `variant` controls layout: 'panel' (stacked, homepage-width)
// or 'footer' (groups sit side by side in the footer settings row).
// idPrefix scopes input names so multiple instances on one page (e.g.
// this component's own showcase entry) don't share radio groups.

interface Props {
  variant: 'panel' | 'footer';
  idPrefix: string;
}

const { variant, idPrefix } = Astro.props;

const themeOptions = [
  { value: 'system', label: 'System' },
  { value: 'light', label: 'Light' },
  { value: 'dark', label: 'Dark' },
];

const contrastOptions = [
  { value: 'low', label: 'Low' },
  { value: 'high', label: 'High' },
  { value: 'system', label: 'System' },
];

const flourishOptions = [
  { value: 'full', label: 'Full' },
  { value: 'reduced', label: 'Reduced' },
  { value: 'raw', label: 'Raw' },
];
---

<div class={`display-controls display-controls--${variant}`}>
  <fieldset class="display-controls__group">
    <legend class="display-controls__legend">Theme</legend>
    <div class="display-controls__segment">
      {themeOptions.map((option) => (
        <label class="display-controls__chip">
          <input
            type="radio"
            name={`${idPrefix}-theme`}
            data-control="theme"
            value={option.value}
            class="visually-hidden"
          />
          <span class="display-controls__chip-label">{option.label}</span>
        </label>
      ))}
    </div>
    <p class="display-controls__live" aria-live="polite" aria-atomic="true">
      Currently: <em data-theme-live>system</em>
    </p>
  </fieldset>

  <fieldset class="display-controls__group">
    <legend class="display-controls__legend">Contrast</legend>
    <div class="display-controls__segment">
      {contrastOptions.map((option) => (
        <label class="display-controls__chip">
          <input
            type="radio"
            name={`${idPrefix}-contrast`}
            data-control="contrast"
            value={option.value}
            class="visually-hidden"
          />
          <span class="display-controls__chip-label">{option.label}</span>
        </label>
      ))}
    </div>
    <p class="display-controls__live" aria-live="polite" aria-atomic="true">
      Currently: <em data-contrast-live>low</em>
    </p>
  </fieldset>

  <fieldset class="display-controls__group">
    <legend class="display-controls__legend">Flourish</legend>
    <div class="display-controls__segment">
      {flourishOptions.map((option) => (
        <label class="display-controls__chip">
          <input
            type="radio"
            name={`${idPrefix}-flourish`}
            data-control="flourish"
            value={option.value}
            class="visually-hidden"
          />
          <span class="display-controls__chip-label">{option.label}</span>
        </label>
      ))}
    </div>
    <p class="display-controls__live" aria-live="polite" aria-atomic="true">
      Currently: <em data-flourish-live>full</em>
    </p>
  </fieldset>
</div>