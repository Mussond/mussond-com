---
import { Sun, Moon, Linkedin } from 'lucide-astro';
import Identity from './Identity.astro';
import IconButton from './IconButton.astro';

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Case studies', href: '/case-studies' },
  { label: 'Guides', href: '/guides' },
  { label: 'Logs', href: '/logs' },
];

const currentPath = Astro.url.pathname;
---

<aside class="sidebar">
  <div class="sidebar__bar">
    <a href="/" class="sidebar__monogram" aria-label="Dave Musson — home">
      <svg class="sidebar__monogram-mark" width="36" height="36" viewBox="0 0 202 196" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
        <path d="M193.435 51.9942C195.417 51.9942 197.155 52.7423 198.61 54.1778C200.201 55.5717 201 57.3868 201 59.5421V136.446C201 138.563 200.316 140.397 198.928 141.88L198.917 141.893L198.904 141.904C197.485 143.32 195.627 143.994 193.435 143.994C191.169 143.994 189.238 143.328 187.734 141.929L187.709 141.905L187.685 141.88C186.298 140.397 185.613 138.563 185.613 136.446V81.8458L163.249 115.813L163.226 115.846L163.202 115.877C162.521 116.75 161.659 117.509 160.633 118.161L160.604 118.179L160.574 118.195C159.491 118.784 158.338 119.044 157.136 118.96C156.001 119.044 154.86 118.775 153.729 118.211L153.682 118.189L153.639 118.161C152.612 117.509 151.751 116.75 151.07 115.877L151.042 115.842L151.017 115.804L128.659 81.0899V136.446C128.659 138.562 127.974 140.394 126.588 141.877L126.589 141.878C125.254 143.311 123.47 143.994 121.351 143.994C119.303 143.994 117.541 143.302 116.139 141.904L116.114 141.88L116.091 141.853C114.8 140.367 114.173 138.543 114.173 136.446V127.874C111.579 131.77 108.381 135.073 104.576 137.775C98.71 141.942 91.4592 143.994 82.8865 143.994H51.4783C49.4304 143.994 47.64 143.304 46.1628 141.929L46.1384 141.904C44.6559 140.426 43.9138 138.584 43.9138 136.446V59.67C43.9139 57.5407 44.6514 55.7344 46.1443 54.335C47.616 52.8698 49.4116 52.1222 51.4783 52.1221H82.8865C89.2801 52.1221 94.9727 53.346 99.9382 55.8223H99.9373C104.879 58.2009 108.991 61.5522 112.26 65.8712H112.26C112.932 66.719 113.569 67.5954 114.173 68.4991V59.5421C114.173 57.4756 114.924 55.681 116.397 54.212L116.409 54.2003L116.421 54.1895C117.97 52.7408 119.799 51.9942 121.866 51.9942C123.065 51.9942 124.281 52.2941 125.503 52.8565C126.77 53.4399 127.78 54.2844 128.494 55.3975L157.545 99.546L187.329 55.3878L187.333 55.3819L187.338 55.3751C188.872 53.1754 190.92 51.9942 193.435 51.9942ZM59.4294 129.669H81.5994C87.5272 129.669 92.2243 128.214 95.781 125.392C99.3981 122.522 102.039 118.746 103.697 114.032L103.701 114.023C105.459 109.18 106.343 103.862 106.344 98.0587C106.344 93.7725 105.838 89.7511 104.833 85.9913L104.827 85.9659C103.91 82.142 102.415 78.7968 100.352 75.9161L100.343 75.9024L100.334 75.8897C98.3663 72.9463 95.8317 70.6631 92.7195 69.0294L92.7058 69.0225L92.6921 69.0147C89.7 67.3209 86.0169 66.4483 81.5994 66.4483H59.4294V129.669Z" fill="currentColor" stroke="currentColor" stroke-width="2"/>
        <path d="M155.655 39.7045C155.655 22.1946 141.461 8 123.951 8H40C22.3269 8 8 22.3269 8 40V156C8 173.673 22.3269 188 40 188H123.951C141.461 188 155.655 173.805 155.655 156.295" stroke="currentColor" stroke-width="16" stroke-linecap="round"/>
      </svg>
    </a>
    <button
      type="button"
      class="sidebar__menu-toggle"
      aria-expanded="false"
      aria-controls="sidebar-body"
      aria-label="Open menu"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
    </button>
  </div>

  <Identity variant="sidebar" />

  <div id="sidebar-body" class="sidebar__body">
    <nav class="sidebar__nav" aria-label="Main">
      <ul id="nav-list" class="sidebar__nav-list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="sidebar__nav-link"
              aria-current={currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) ? 'page' : undefined}
            >{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="sidebar__socials">
      <IconButton
        href="https://www.linkedin.com/in/davemusson/"
        label="LinkedIn profile (opens in new tab)"
      >
        <Linkedin aria-hidden="true" width="18" height="18" />
      </IconButton>
      <IconButton
        label="Theme and contrast settings"
        aria-haspopup="dialog"
        aria-controls="theme-drawer"
      >
        <Sun class="icon-button__theme-icon icon-button__theme-icon--sun" aria-hidden="true" width="18" height="18" />
        <Moon class="icon-button__theme-icon icon-button__theme-icon--moon" aria-hidden="true" width="18" height="18" />
      </IconButton>
    </div>

    <div class="sidebar__status">
      <span class="sidebar__status-dot" aria-hidden="true"></span>
      <p class="sidebar__status-body">Available for speaking, mentoring, and accessibility or design systems engagements.</p>
    </div>
  </div>
</aside>

<script>
  const toggle = document.querySelector('.sidebar__menu-toggle') as HTMLButtonElement;
  const body = document.getElementById('sidebar-body') as HTMLElement;

  function updateMenuLabel(isOpen: boolean) {
    toggle?.setAttribute('aria-label', isOpen ? 'Close menu' : 'Open menu');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = body.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    updateMenuLabel(isOpen);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    if (!body.classList.contains('is-open')) return;

    body.classList.remove('is-open');
    toggle?.setAttribute('aria-expanded', 'false');
    updateMenuLabel(false);
    toggle?.focus();
  });
</script>
