---
// Detail-page header block — used on guide and log detail pages.
// Renders: eyebrow (published date), h1 title, leading description, tag list, updated meta line.
// CSS lives in styles/components/prose.css (.content-header, .content-eyebrow, .content-meta).

import TagList from './TagList.astro';

interface Props {
  title: string;
  description: string;
  tags: string[];
  date: Date;
  updatedAt?: Date;
}

const { title, description, tags, date, updatedAt } = Astro.props;

const dateLabel = date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const updatedLabel = updatedAt?.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<div class="content-header">
  <p class="content-eyebrow">Published {dateLabel}</p>
  <h1>{title}</h1>
  <p class="text-leading">{description}</p>
  <TagList tags={tags} size="pill" />
  {updatedLabel && <p class="content-meta">Last updated {updatedLabel}</p>}
</div>
