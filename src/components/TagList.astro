---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <div class="card__tags">
    {tags.map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
)}

<style>
  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
