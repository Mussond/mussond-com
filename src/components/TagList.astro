---
interface Props {
  tags: string[];
  size?: 'default' | 'xs';
}

const { tags, size = 'default' } = Astro.props;
const wrapClass = size === 'xs' ? 'card__tags card__tags--xs' : 'card__tags';
const tagClass = size === 'xs' ? 'tag tag--xs' : 'tag';
---

{tags.length > 0 && (
  <div class={wrapClass}>
    {tags.map((tag) => (
      <span class={tagClass}>{tag}</span>
    ))}
  </div>
)}
