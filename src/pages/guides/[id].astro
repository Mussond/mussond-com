---
import Layout from '../../layouts/Layout.astro';
import BackLink from '../../components/BackLink.astro';
import ContentHeader from '../../components/ContentHeader.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('guides');
  return articles.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

interface Props {
  article: Awaited<ReturnType<typeof getCollection<'guides'>>>[number];
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<Layout title={`${article.data.title} — Dave Musson`} description={article.data.description}>
  <main id="main-content" class="container page-content">

    <BackLink href="/guides" label="Guides" />

    <ContentHeader
      title={article.data.title}
      description={article.data.description}
      tags={article.data.tags}
      date={article.data.date}
      updatedAt={article.data.updatedAt}
    />

    <div class="prose">
      <Content />
    </div>

  </main>
</Layout>