---
import Layout from '../../layouts/Layout.astro';
import GuideCard from '../../components/GuideCard.astro';
import TagFilterList from '../../components/TagFilterList.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('guides');
const sorted = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const allTags = [...new Set(sorted.flatMap((a) => a.data.tags))].sort();
---

<Layout title="Guides — Dave Musson" description="Guides on design systems and accessibility by Dave Musson.">
  <main id="main-content" class="container page-content">
    <h1>Guides</h1>
    <p class="text-leading page-intro">
      Articles on design systems and accessibility.
    </p>

    <TagFilterList tags={allTags} listId="article-list" />

    <ul class="guide-card-feed" id="article-list">
      {sorted.map((article, idx) => {
        const words = article.body?.split(/\s+/).length ?? 0;
        const readTime = Math.max(1, Math.round(words / 200));
        return (
          <li data-tags={article.data.tags.join(',')}>
            <GuideCard
              href={`/guides/${article.id}`}
              title={article.data.title}
              description={article.data.description}
              index={idx + 1}
              readTime={readTime}
              date={article.data.date}
              headingLevel={2}
            />
          </li>
        );
      })}
    </ul>
  </main>
</Layout>