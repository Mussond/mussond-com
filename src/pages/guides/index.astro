---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('guides');
const sorted = articles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const allTags = [...new Set(sorted.flatMap((a) => a.data.tags))].sort();
---

<Layout title="Guides — Dave Musson" description="Guides on design systems and accessibility by Dave Musson.">
  <main id="main-content" class="container" style="padding-block: 4rem;">
    <h1>Guides</h1>
    <p class="text-leading" style="margin-top: 1rem; margin-bottom: 2rem;">
      Articles on design systems and accessibility.
    </p>

    <div class="tag-filter" role="group" aria-label="Filter by tag">
      <button class="tag tag--filter" data-tag="all" aria-pressed="true">All</button>
      {allTags.map((tag) => (
        <button class="tag tag--filter" data-tag={tag} aria-pressed="false">{tag}</button>
      ))}
    </div>
    <p class="visually-hidden" id="filter-status" aria-live="polite" aria-atomic="true"></p>

    <ul class="card-list" id="article-list" style="margin-top: 2.5rem;">
      {sorted.map((article) => (
        <li class="card-list__item" data-tags={article.data.tags.join(',')}>
          <Card
            href={`/guides/${article.id}`}
            title={article.data.title}
            description={article.data.description}
            tags={article.data.tags}
            headingLevel={2}
          />
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag--filter {
    cursor: pointer;
    background: transparent;
    border: 2px solid currentColor;
    font-family: inherit;
    font-size: inherit;
  }

  .tag--filter:hover {
  background-color: var(--color-action-bg);
  border-color: var(--color-action-border);
  color: var(--color-action-text);
}

  .tag--filter[aria-pressed="true"] {
    background-color: var(--color-text-primary);
    color: var(--color-bg-base);
    border-color: var(--color-text-primary);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .card-list__item[hidden] { display: none; }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag--filter');
  const items = document.querySelectorAll<HTMLLIElement>('.card-list__item');
  const status = document.getElementById('filter-status');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.tag ?? 'all';
      let visibleCount = 0;

      buttons.forEach((b) => {
        b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
      });

      items.forEach((item) => {
        const tags = (item.dataset.tags ?? '').split(',');
        const hide = selected !== 'all' && !tags.includes(selected);
        item.hidden = hide;
        if (!hide) visibleCount++;
      });

      if (status) {
        status.textContent = selected === 'all'
          ? `Showing all ${items.length} guides`
          : `Showing ${visibleCount} guides`;
      }
    });
  });
</script>
