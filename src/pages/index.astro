---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import GuideCard from '../components/GuideCard.astro';
import LogCard from '../components/LogCard.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');
const sortedCaseStudies = caseStudies
  .filter((study) => study.data.coverImage !== undefined)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const writing = await getCollection('guides');
const sortedWriting = writing
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map((article) => {
    const words = article.body?.split(/\s+/).length ?? 0;
    return { ...article, readTime: Math.max(1, Math.round(words / 200)) };
  });

const logs = await getCollection('logs');
const sortedLogs = logs
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2)
  .map((log) => ({ ...log, year: (log.data.updatedAt ?? log.data.date).getFullYear() }));
---

<Layout
  title="Dave Musson — Design Systems and Accessibility specialist"
  description="Dave Musson is a Principal Design Systems Designer and accessibility specialist with 16 years of experience."
>
  <main id="main-content">

    <Hero />

    <section class="preview container" aria-labelledby="cs-heading">
      <SectionHeader
        eyebrow="Selected Work"
        heading="Case studies"
        headingId="cs-heading"
        viewAllHref="/case-studies"
      />
      {sortedCaseStudies.length > 0 && (
        <div class="cs-card-section">
          <CaseStudyCard
            variant="featured"
            href={`/case-studies/${sortedCaseStudies[0].id}`}
            title={sortedCaseStudies[0].data.title}
            description={sortedCaseStudies[0].data.description}
            tags={sortedCaseStudies[0].data.tags}
            cover={sortedCaseStudies[0].data.cover}
            image={sortedCaseStudies[0].data.cardImage || sortedCaseStudies[0].data.coverImage}
            headingLevel={3}
          />
          {sortedCaseStudies.length > 1 && (
            <div class="cs-secondary-grid">
              {sortedCaseStudies.slice(1).map((study) => (
                <CaseStudyCard
                  variant="secondary"
                  href={`/case-studies/${study.id}`}
                  title={study.data.title}
                  description={study.data.description}
                  tags={study.data.tags}
                  cover={study.data.cover}
                  image={study.data.cardImage || study.data.coverImage}
                  headingLevel={3}
                />
              ))}
            </div>
          )}
        </div>
      )}
    </section>

    <section class="preview container" aria-labelledby="guides-heading">
      <SectionHeader
        eyebrow="Long-form writing"
        heading="Guides"
        headingId="guides-heading"
        viewAllHref="/guides"
      />
      <ul class="guide-card-grid">
        {sortedWriting.map((article) => (
          <li>
            <GuideCard
              href={`/guides/${article.id}`}
              title={article.data.title}
              description={article.data.description}
              tags={article.data.tags}
              readTime={article.readTime}
            />
          </li>
        ))}
      </ul>
    </section>

    <section class="preview container" aria-labelledby="logs-heading">
      <SectionHeader
        eyebrow="Curated resources"
        heading="Logs"
        headingId="logs-heading"
        viewAllHref="/logs"
      />
      <ul class="log-card-list">
        {sortedLogs.map((log) => (
          <li>
            <LogCard
              href={`/logs/${log.id}`}
              title={log.data.title}
              description={log.data.description}
              tags={log.data.tags}
              year={log.year}
            />
          </li>
        ))}
      </ul>
    </section>

  </main>
</Layout>

<style>
  .preview {
    padding-block: 3rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border-default) 20%, transparent);
  }
</style>
