---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');
const sortedCaseStudies = caseStudies
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);

const writing = await getCollection('writing');
const sortedWriting = writing
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);

const logs = await getCollection('logs');
const sortedLogs = logs
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 2);
---

<Layout
  title="Dave Musson — Design Systems and Accessibility specialist"
  description="Dave Musson is a Principal Design Systems Designer and accessibility specialist with 16 years of experience."
>
  <main id="main-content">

    <section class="hero container" aria-labelledby="hero-heading">
      <h1 id="hero-heading">Dave Musson</h1>
      <p class="text-leading hero__intro">
        I'm an accessibility advocate and design systems specialist.
        I foster cross-discipline environments for collaboration, trust, and compassion.
      </p>
      <div class="hero__actions">
        <a href="/case-studies" class="btn">View case studies</a>
        <a href="/about" class="btn btn--secondary">About me</a>
      </div>
    </section>

    <section class="preview container" aria-labelledby="cs-heading">
      <div class="preview__header">
        <h2 id="cs-heading">Case studies</h2>
        <a href="/case-studies" class="preview__link">View all<span class="visually-hidden"> case studies</span></a>
      </div>
      <ul class="card-list">
        {sortedCaseStudies.map((study) => (
          <li>
            <a href={`/case-studies/${study.id}`} class="card">
              {(study.data.cardImage || study.data.coverImage) && (
                <img
                  src={study.data.cardImage || study.data.coverImage}
                  alt=""
                  class="card__image"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <div class="card__content">
                <h3 class="card__title">{study.data.title}</h3>
                <p class="card__description">{study.data.description}</p>
                <div class="card__tags">
                  {study.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="preview container" aria-labelledby="writing-heading">
      <div class="preview__header">
        <h2 id="writing-heading">Writing</h2>
        <a href="/writing" class="preview__link">View all<span class="visually-hidden"> writing</span></a>
      </div>
      <ul class="card-list">
        {sortedWriting.map((article) => (
          <li>
            <a href={`/writing/${article.id}`} class="card card--no-image">
              <div class="card__content">
                <h3 class="card__title">{article.data.title}</h3>
                <p class="card__description">{article.data.description}</p>
                <div class="card__tags">
                  {article.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="preview container" aria-labelledby="logs-heading">
      <div class="preview__header">
        <h2 id="logs-heading">Logs</h2>
        <a href="/logs" class="preview__link">View all<span class="visually-hidden"> logs</span></a>
      </div>
      <ul class="card-list">
        {sortedLogs.map((log) => (
          <li>
            <a href={`/logs/${log.id}`} class="card card--no-image">
              <div class="card__content">
                <h3 class="card__title">{log.data.title}</h3>
                <p class="card__description">{log.data.description}</p>
                <div class="card__tags">
                  {log.data.tags.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>

  </main>
</Layout>

<style>
  .hero {
    padding-block: 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero h1 { margin: 0; }
  .hero__intro { max-width: 52ch; }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .btn--secondary {
    background: transparent;
    color: var(--color-text-primary);
  }

  .btn--secondary:hover,
  .btn--secondary:focus-visible {
    background: var(--color-bg-card);
  }

  .preview {
    padding-block: 3rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border-default) 20%, transparent);
  }

  .preview__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .preview__header h2 { margin: 0; }

  .preview__link {
    font-size: 1rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .card-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .card--no-image { grid-template-columns: 1fr; }
  .card--no-image .card__content { padding: var(--space-md); }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
