---
import Layout from '../layouts/Layout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import GuideCard from '../components/GuideCard.astro';
import GuideCardFeed from '../components/GuideCardFeed.astro';
import LogCard from '../components/LogCard.astro';
import LogCardFeed from '../components/LogCardFeed.astro';
import Hero from '../components/Hero.astro';
import HeroStats from '../components/HeroStats.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');
const sortedCaseStudies = caseStudies
  .filter((study) => study.data.cover !== undefined)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const writing = await getCollection('guides');
const sortedWriting = writing
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map((article) => {
    const words = article.body?.split(/\s+/).length ?? 0;
    return { ...article, readTime: Math.max(1, Math.round(words / 200)) };
  });

const logs = await getCollection('logs');
const sortedLogs = logs
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2)
.map((log) => ({ ...log, year: (log.data.updatedAt ?? log.data.date).getFullYear(), href: log.data.externalUrl ?? `/logs/${log.id}` }));
---

<Layout
  title="Dave Musson — Design Systems and Accessibility specialist"
  description="Dave Musson is a Principal Design Systems Designer and accessibility specialist with 16 years of experience."
>
  <main id="main-content">

    <Hero />

    <HeroStats />

    <section class="section-preview container" aria-labelledby="cs-heading">
      <SectionHeader
        eyebrow="Selected Work"
        heading="Case studies"
        headingId="cs-heading"
        viewAllHref="/case-studies"
      />
      {sortedCaseStudies.length > 0 && (
        <div class="cs-card-row-list">
          {sortedCaseStudies.map((study) => (
            <CaseStudyCard
              variant="row"
              href={`/case-studies/${study.id}`}
              title={study.data.title}
              tags={study.data.cardTags ?? study.data.tags}
              year={study.data.date.getFullYear()}
              cover={study.data.cover}
              headingLevel={3}
            />
          ))}
        </div>
      )}
    </section>

    <section class="section-preview container" aria-labelledby="guides-heading">
      <SectionHeader
        eyebrow="Long-form writing"
        heading="Guides"
        headingId="guides-heading"
        viewAllHref="/guides"
      />
      <GuideCardFeed>
        {sortedWriting.map((article, idx) => (
          <li>
            <GuideCard
              href={`/guides/${article.id}`}
              title={article.data.title}
              description={article.data.description}
              index={idx + 1}
              readTime={article.readTime}
              date={article.data.date}
            />
          </li>
        ))}
      </GuideCardFeed>
    </section>

    <section class="section-preview container" aria-labelledby="logs-heading">
      <SectionHeader
        eyebrow="Curated resources"
        heading="Logs"
        headingId="logs-heading"
        viewAllHref="/logs"
      />
      <LogCardFeed>
        {sortedLogs.map((log) => (
          <li>
            <LogCard
              href={log.href}
              title={log.data.title}
              description={log.data.description}
              year={log.year}
              external={!!log.data.externalUrl}
            />
          </li>
        ))}
      </LogCardFeed>
    </section>

  </main>
</Layout>
