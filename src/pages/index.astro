---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Hero from '../components/Hero.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');
const sortedCaseStudies = caseStudies
  .filter((study) => study.data.coverImage !== undefined)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const writing = await getCollection('guides');
const sortedWriting = writing
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const logs = await getCollection('logs');
const sortedLogs = logs
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<Layout
  title="Dave Musson — Design Systems and Accessibility specialist"
  description="Dave Musson is a Principal Design Systems Designer and accessibility specialist with 16 years of experience."
>
  <main id="main-content">

    <Hero />

    <section class="preview container" aria-labelledby="cs-heading">
      <div class="preview__header">
        <h2 id="cs-heading">Case studies</h2>
        <a href="/case-studies" class="preview__link">View all<span class="visually-hidden"> case studies</span></a>
      </div>
      <ul class="card-list">
        {sortedCaseStudies.map((study) => (
          <li>
            <Card
              href={`/case-studies/${study.id}`}
              title={study.data.title}
              description={study.data.description}
              tags={study.data.tags}
              image={study.data.cardImage || study.data.coverImage}
            />
          </li>
        ))}
      </ul>
    </section>

    <section class="preview container" aria-labelledby="guides-heading">
      <div class="preview__header">
        <h2 id="guides-heading">Guides</h2>
        <a href="/guides" class="preview__link">View all<span class="visually-hidden"> guides</span></a>
      </div>
      <ul class="card-list">
        {sortedWriting.map((article) => (
          <li>
            <Card
              href={`/guides/${article.id}`}
              title={article.data.title}
              description={article.data.description}
              tags={article.data.tags}
            />
          </li>
        ))}
      </ul>
    </section>

    <section class="preview container" aria-labelledby="logs-heading">
      <div class="preview__header">
        <h2 id="logs-heading">Logs</h2>
        <a href="/logs" class="preview__link">View all<span class="visually-hidden"> logs</span></a>
      </div>
      <ul class="card-list">
        {sortedLogs.map((log) => (
          <li>
            <Card
              href={`/logs/${log.id}`}
              title={log.data.title}
              description={log.data.description}
              tags={log.data.tags}
            />
          </li>
        ))}
      </ul>
    </section>

  </main>
</Layout>

<style>
  .preview {
    padding-block: 3rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border-default) 20%, transparent);
  }

  .preview__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .preview__header h2 { margin: 0; }

  .preview__link {
    font-size: 1rem;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }

</style>
