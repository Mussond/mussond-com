---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const logs = await getCollection('logs');
const sorted = logs.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Layout title="Logs — Dave Musson" description="A running log of resources, notes and references gathered over time.">
  <main id="main-content" class="container" style="padding-block: 4rem;">
    <h1>Logs</h1>
    <p class="text-leading" style="margin-top: 1rem; margin-bottom: 3rem;">
      A running log of resources, notes and references gathered over time.
    </p>
    <ul class="card-list">
      {sorted.map((log) => (
        <li>
          <Card
            href={`/logs/${log.id}`}
            title={log.data.title}
            description={log.data.description}
            tags={log.data.tags}
            headingLevel={2}
          />
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  .card-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
