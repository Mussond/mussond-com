---
import Layout from '../../layouts/Layout.astro';
import LogCard from '../../components/LogCard.astro';
import { getCollection } from 'astro:content';

const logs = await getCollection('logs');
const sorted = logs.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Logs — Dave Musson" description="Reference lists I keep returning to. Curated, not comprehensive. Last reviewed per list.">
  <main id="main-content" class="container page-content">
    <h1>Logs</h1>
    <p class="text-leading page-intro">
      Reference lists I keep returning to. Curated, not comprehensive. Last reviewed per list.
    </p>
    <ul class="log-card-list">
      {sorted.map((log, idx) => {
        const year = (log.data.updatedAt ?? log.data.date).getFullYear();
        return (
          <li>
            <LogCard
              href={`/logs/${log.id}`}
              title={log.data.title}
              description={log.data.description}
              index={idx + 1}
              year={year}
              headingLevel={2}
            />
          </li>
        );
      })}
    </ul>
  </main>
</Layout>