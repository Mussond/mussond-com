---
import Layout from '../../layouts/Layout.astro';
import BackLink from '../../components/BackLink.astro';
import ContentHeader from '../../components/ContentHeader.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const logs = await getCollection('logs');
  return logs.map((log) => ({
    params: { id: log.id },
    props: { log },
  }));
}

interface Props {
  log: Awaited<ReturnType<typeof getCollection<'logs'>>>[number];
}

const { log } = Astro.props;
const { Content } = await render(log);
---

<Layout title={`${log.data.title} — Dave Musson`} description={log.data.description}>
  <main id="main-content" class="container page-content">

    <BackLink href="/logs" label="Logs" />

    <ContentHeader
      title={log.data.title}
      description={log.data.description}
      tags={log.data.tags}
      date={log.data.date}
      updatedAt={log.data.updatedAt}
    />

    <div class="prose">
      <Content />
    </div>

  </main>
</Layout>