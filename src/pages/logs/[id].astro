---
import Layout from '../../layouts/Layout.astro';
import BackLink from '../../components/BackLink.astro';
import TagList from '../../components/TagList.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const logs = await getCollection('logs');
  return logs.map((log) => ({
    params: { id: log.id },
    props: { log },
  }));
}

interface Props {
  log: Awaited<ReturnType<typeof getCollection<'logs'>>>[number];
}

const { log } = Astro.props;
const { Content } = await render(log);
---

<Layout title={`${log.data.title} — Dave Musson`} description={log.data.description}>
  <main id="main-content" class="container" style="padding-block: 4rem;">

    <BackLink href="/logs" label="Logs" />

    <div class="content-header">
      <h1>{log.data.title}</h1>
      <p class="text-leading">{log.data.description}</p>
      <TagList tags={log.data.tags} />
      <p class="content-meta">
        Published {log.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        {log.data.updatedAt && (
          <> · Last updated {log.data.updatedAt.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</>
        )}
      </p>
    </div>

    <div class="prose">
      <Content />
    </div>

  </main>
</Layout>