---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — Dave Musson" description="The page you were looking for doesn't exist or has moved.">
  <main id="main-content" class="container" style="padding-block: 4rem;">
    <h1>Page not found</h1>
    <p class="text-leading" style="margin-top: 1rem; margin-bottom: 2rem;">
      Sorry — this page doesn't exist or has moved.
    </p>
    <nav aria-label="Main sections">
      <ul class="nav-list">
        <li><a href="/">Home</a></li>
        <li><a href="/case-studies">Case studies</a></li>
        <li><a href="/guides">Guides</a></li>
        <li><a href="/logs">Logs</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>
  </main>
</Layout>

<style>
  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .nav-list a {
    font-weight: 600;
    color: var(--color-text-secondary);
  }
</style>
