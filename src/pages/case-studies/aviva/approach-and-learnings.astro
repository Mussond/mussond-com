---
import CaseStudyLayout from '../../../components/CaseStudyLayout.astro';
import { getEntry, render } from 'astro:content';

const study = await getEntry('case-studies', 'aviva-approach-and-learnings');
if (!study) return Astro.redirect('/case-studies/aviva');

const { Content } = await render(study);
---

<CaseStudyLayout
  study={study}
  backHref="/case-studies/aviva"
  backLabel="Aviva case study"
>
  <Content />
</CaseStudyLayout>
