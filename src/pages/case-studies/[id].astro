---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const caseStudies = await getCollection('case-studies');
  return caseStudies.map((study) => ({
    params: { id: study.id },
    props: { study },
  }));
}

interface Props {
  study: Awaited<ReturnType<typeof getCollection<'case-studies'>>>[number];
}

const { study } = Astro.props;
const { Content } = await render(study);
---

<Layout title={`${study.data.title} — Dave Musson`} description={study.data.description}>
  <main class="container" style="padding-block: 4rem;">

    <a href="/case-studies" class="back-link">← Case studies</a>

    <div class="case-study-header">
      <h1>{study.data.title}</h1>
      <p class="text-leading">{study.data.description}</p>
      <div class="tags">
        {study.data.tags.map((tag: string) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>

    {study.data.coverImage && (
      <img
        src={study.data.coverImage}
        alt=""
        class="hero-image"
        loading="eager"
        decoding="async"
      />
    )}

    <div class="case-study-body">
      <Content />
    </div>

  </main>
</Layout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    font-weight: 600;
    text-decoration: underline 0.15em;
    text-underline-position: under;
  }

  .hero-image {
    width: 100%;
    border-radius: 16px;
    margin-bottom: 3rem;
  }

  .case-study-header {
    margin-bottom: 2rem;
  }

  .case-study-header h1 {
    margin-bottom: 1rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .case-study-body {
    max-width: 68ch;
  }

  .case-study-body :global(h2) {
    font-size: 2.1875rem;
    font-weight: 500;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  .case-study-body :global(h3) {
    font-size: 1.5625rem;
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .case-study-body :global(p) {
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .case-study-body :global(ul) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
    list-style: disc;
  }

  .case-study-body :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
    display: list-item;
  }

  .case-study-body :global(a) {
    color: var(--color-text-secondary);
    font-weight: 600;
  }
</style>