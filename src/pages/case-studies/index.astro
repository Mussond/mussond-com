---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');
const sorted = caseStudies.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Layout title="Case studies — Dave Musson" description="Career case studies from Dave Musson, Design Systems and Accessibility specialist.">
  <main id="main-content" class="container" style="padding-block: 4rem;">
    <h1>Case studies</h1>
    <p class="text-leading" style="margin-top: 1rem; margin-bottom: 3rem;">
      A selection of career case studies across design systems, accessibility, and DesignOps.
    </p>
    <ul class="card-list">
      {sorted.map((study) => (
        <li>
          <a href={`/case-studies/${study.id}`} class="card">
            {study.data.coverImage && (
              <img
                src={study.data.cardImage || study.data.coverImage}
                alt=""
                class="card__image"
                loading="lazy"
                decoding="async"
              />
            )}
            <div class="card__content">
              <h2 class="card__title">{study.data.title}</h2>
              <p class="card__description">{study.data.description}</p>
              <div class="card__tags">
                {study.data.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  .card-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
