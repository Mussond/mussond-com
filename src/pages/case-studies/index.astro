---
import Layout from '../../layouts/Layout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');
const withCovers = caseStudies.filter((study) => study.data.coverImage !== undefined);
const featuredStudy = withCovers.find((study) => study.data.featured);
const nonFeatured = withCovers
  .filter((study) => !study.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const sorted = featuredStudy ? [featuredStudy, ...nonFeatured] : nonFeatured;
---

<Layout title="Case studies — Dave Musson" description="Career case studies from Dave Musson, Design Systems and Accessibility specialist.">
  <main id="main-content" class="container page-content">
    <h1>Case studies</h1>
    <p class="text-leading page-intro">
      A selection of career case studies across design systems, accessibility, and DesignOps.
    </p>
    {sorted.length > 0 && (
      <div class="cs-card-section">
        <CaseStudyCard
          variant="featured"
          href={`/case-studies/${sorted[0].id}`}
          title={sorted[0].data.title}
          description={sorted[0].data.description}
          tags={sorted[0].data.cardTags ?? sorted[0].data.tags}
          year={sorted[0].data.date.getFullYear()}
          cover={sorted[0].data.cover}
          image={sorted[0].data.cardImage || sorted[0].data.coverImage}
          headingLevel={2}
        />
        {sorted.length > 1 && (
          <div class="cs-secondary-grid">
            {sorted.slice(1).map((study) => (
              <CaseStudyCard
                variant="secondary"
                href={`/case-studies/${study.id}`}
                title={study.data.title}
                description={study.data.description}
                tags={study.data.cardTags ?? study.data.tags}
                year={study.data.date.getFullYear()}
                cover={study.data.cover}
                image={study.data.cardImage || study.data.coverImage}
                headingLevel={2}
              />
            ))}
          </div>
        )}
      </div>
    )}
  </main>
</Layout>
