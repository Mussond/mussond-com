---
import Layout from '../../layouts/Layout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');
const sorted = caseStudies.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Layout title="Case studies — Dave Musson" description="Career case studies from Dave Musson, Design Systems and Accessibility specialist.">
  <main id="main-content" class="container" style="padding-block: 4rem;">
    <h1>Case studies</h1>
    <p class="text-leading" style="margin-top: 1rem; margin-bottom: 3rem;">
      A selection of career case studies across design systems, accessibility, and DesignOps.
    </p>
    <ul class="card-list">
      {sorted.map((study) => (
        <li>
          <Card
            href={`/case-studies/${study.id}`}
            title={study.data.title}
            description={study.data.description}
            tags={study.data.tags}
            image={study.data.coverImage ? (study.data.cardImage || study.data.coverImage) : undefined}
            headingLevel={2}
          />
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  .card-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
