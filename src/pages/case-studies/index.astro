---
import Layout from '../../layouts/Layout.astro';
import CaseStudyCard from '../../components/CaseStudyCard.astro';
import CaseStudyGrid from '../../components/CaseStudyGrid.astro';
import PageIntro from '../../components/PageIntro.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');
const withCovers = caseStudies.filter((study) => study.data.coverImage !== undefined);
const featuredStudy = withCovers.find((study) => study.data.featured);
const nonFeatured = withCovers
  .filter((study) => !study.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const sorted = featuredStudy ? [featuredStudy, ...nonFeatured] : nonFeatured;
---

<Layout title="Case studies — Dave Musson" description="Career case studies from Dave Musson, Design Systems and Accessibility specialist.">
  <main id="main-content" class="container page-content">
    <h1>Case studies</h1>
    <PageIntro>
      <p>A selection of career case studies across design systems, accessibility, and DesignOps.</p>
    </PageIntro>
    {sorted.length > 0 && (
      <CaseStudyGrid>
        {sorted.map((study) => (
          <CaseStudyCard
            variant="featured"
            href={`/case-studies/${study.id}`}
            title={study.data.title}
            description={study.data.description}
            tags={study.data.tags}
            year={study.data.date.getFullYear()}
            stats={study.data.stats}
            cover={study.data.cover}
            image={study.data.cardImage || study.data.coverImage}
            headingLevel={2}
          />
        ))}
      </CaseStudyGrid>
    )}
  </main>
</Layout>
